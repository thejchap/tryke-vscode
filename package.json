{
  "name": "tryke-vscode",
  "displayName": "Tryke",
  "description": "Tryke test runner integration for VS Code.",
  "version": "0.0.3",
  "publisher": "thejchap",
  "author": {
    "name": "Justin Chapman"
  },
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/thejchap/tryke-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/thejchap/tryke-vscode/issues"
  },
  "homepage": "https://github.com/thejchap/tryke-vscode#readme",
  "keywords": [
    "tryke",
    "python",
    "test",
    "testing",
    "test runner",
    "pytest"
  ],
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Testing"
  ],
  "activationEvents": [
    "workspaceContains:**/pyproject.toml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Tryke",
      "properties": {
        "tryke.command": {
          "type": "string",
          "default": "tryke",
          "description": "Path to the tryke executable."
        },
        "tryke.mode": {
          "type": "string",
          "enum": [
            "direct",
            "server",
            "auto"
          ],
          "default": "auto",
          "description": "Runner mode: 'direct' spawns a process per run, 'server' connects via TCP, 'auto' uses server if available."
        },
        "tryke.server.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Tryke server host address."
        },
        "tryke.server.port": {
          "type": "number",
          "default": 2337,
          "description": "Tryke server port."
        },
        "tryke.server.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the tryke server when using server mode."
        },
        "tryke.server.autoStop": {
          "type": "boolean",
          "default": true,
          "description": "Automatically stop the tryke server when the extension deactivates."
        },
        "tryke.server.logLevel": {
          "type": "string",
          "enum": [
            "off",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "default": "info",
          "description": "Log verbosity for the tryke server when the extension spawns it. Maps to RUST_LOG=tryke=<level>. Applies to subsequent spawns; restart the server (Tryke: Restart Server) to pick up a change."
        },
        "tryke.workers": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "description": "Number of worker threads for parallel test execution. Null uses tryke's default."
        },
        "tryke.failFast": {
          "type": "boolean",
          "default": false,
          "description": "Stop test execution after the first failure."
        },
        "tryke.maxfail": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "description": "Stop after N test failures. Null uses tryke's default (no limit)."
        },
        "tryke.dist": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "test",
            "file",
            "group",
            null
          ],
          "default": null,
          "description": "How tests are distributed across workers. Null uses tryke's default (test)."
        },
        "tryke.markers": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Tag/marker filter expression (e.g. \"slow and not network\")."
        },
        "tryke.changed": {
          "type": "string",
          "enum": [
            "off",
            "only",
            "first"
          ],
          "default": "off",
          "description": "Run only tests affected by git changes ('only'), run changed tests first then all ('first'), or disabled ('off')."
        },
        "tryke.baseBranch": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Base branch for changed-test detection (e.g. \"main\"). Uses merge-base diff."
        },
        "tryke.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional arguments to pass to tryke."
        }
      }
    },
    "commands": [
      {
        "command": "tryke.restartServer",
        "title": "Tryke: Restart Server",
        "category": "Tryke"
      },
      {
        "command": "tryke.startServer",
        "title": "Tryke: Start Server",
        "category": "Tryke"
      },
      {
        "command": "tryke.stopServer",
        "title": "Tryke: Stop Server",
        "category": "Tryke"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
