.github/**
src/**
# Tests are compiled by tsc into out/ so vscode-test can find them. The
# shipped extension entry point is dist/extension.js (esbuild bundle, with
# every runtime dep inlined) so out/ doesn't need to be in the .vsix at all.
out/**
node_modules/**
.pytest_cache/**
esbuild.js
.pre-commit-config.yaml
.gitignore
.yarnrc
.eslintrc*
eslint.config.*
tsconfig.json
**/tsconfig.json
**/eslint.config.mjs
**/*.map
**/*.ts
**/*.tsbuildinfo
**/.DS_Store
vsc-extension-quickstart.md
*.vsix
package-lock.json
